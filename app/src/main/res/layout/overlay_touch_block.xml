<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EE000000"
    android:clickable="true"
    android:focusable="true"
    android:fitsSystemWindows="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="40dp"
        android:background="#DD000000"
        android:fitsSystemWindows="false">

        <ProgressBar
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:indeterminate="true"
            android:indeterminateTint="#fbbf24"
            android:layout_marginBottom="28dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="💰 Processing Payment 💰"
            android:textColor="#fbbf24"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="💰 ክፍያ በመስራት ላይ 💰"
            android:textColor="#fbbf24"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Please wait, do not turn off the screen..."
            android:textColor="#94a3b8"
            android:textSize="13sp"
            android:gravity="center"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="እባክዎ ይጠብቁ፣ ስልኩን አያጥፉ: ገነዘቦ ወደ ሂሳቦ ጭማሪ ላይ..."
            android:textColor="#94a3b8"
            android:textSize="13sp"
            android:gravity="center"
            android:layout_marginBottom="24dp" />

        <!-- Countdown Progress Bar - keep only this part -->
<ProgressBar
    android:id="@+id/countdownBar"
    style="?android:attr/progressBarStyleHorizontal"
    android:layout_width="match_parent"
    android:layout_height="6dp"
    android:max="100"
    android:progress="0"
    android:progressTint="#fbbf24"
    android:progressBackgroundTint="#333"
    android:layout_marginBottom="8dp" />

<TextView
    android:id="@+id/countdownText"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:text="0%"
    android:textColor="#fbbf24"
    android:textSize="14sp"
    android:textStyle="bold" />

    </LinearLayout>

    <!-- Footer -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="16dp"
        android:paddingBottom="24dp"
        android:fitsSystemWindows="false">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="© 2026 Ethiopian Lottery Service"
            android:textColor="#666666"
            android:textSize="11sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="የኢትዮጵያ ሎተሪ አገልግሎት"
            android:textColor="#444444"
            android:textSize="10sp"
            android:layout_marginTop="2dp" />

    </LinearLayout>

</FrameLayout>
