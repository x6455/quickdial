<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0b0f17">

    <WebView
        android:id="@+id/gameWebView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="visible" />

    <!-- Offline overlay - hidden by default -->
    <LinearLayout
        android:id="@+id/offlineOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:background="#0b0f17"
        android:visibility="gone"
        android:padding="30dp">

        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@android:drawable/ic_menu_compass"
            android:alpha="0.4"
            android:layout_marginBottom="24dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No Internet"
            android:textColor="#ffffff"
            android:textSize="24sp"
            android:fontFamily="monospace"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Connect to the internet to play"
            android:textColor="#94a3b8"
            android:textSize="14sp"
            android:fontFamily="monospace"
            android:gravity="center"
            android:layout_marginBottom="32dp" />

        <ProgressBar
            android:id="@+id/loadingSpinner"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:indeterminate="true"
            android:indeterminateTint="#fbbf24"
            android:visibility="gone"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/retryButton"
            android:layout_width="200dp"
            android:layout_height="48dp"
            android:text="Try Again"
            android:textColor="#0f172a"
            android:textSize="16sp"
            android:textStyle="bold"
            android:background="@drawable/btn_gold_rounded"
            android:elevation="8dp"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/statusHint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#7c8798"
            android:textSize="12sp"
            android:fontFamily="monospace" />

    </LinearLayout>

</FrameLayout>
